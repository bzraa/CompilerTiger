   78 fundec: FUNCTION ID LPAREN tyfields_opt RPAREN COLON ID EQ . exp

    ID      shift, and go to state 1
    STRING  shift, and go to state 2
    INT     shift, and go to state 3
    LPAREN  shift, and go to state 4
    MINUS   shift, and go to state 5
    IF      shift, and go to state 6
    WHILE   shift, and go to state 7
    FOR     shift, and go to state 8
    LET     shift, and go to state 9
    BREAK   shift, and go to state 10
    NIL     shift, and go to state 11

    exp        go to state 171
    assignexp  go to state 14
    orexp      go to state 15
    andexp     go to state 16
    relexp     go to state 17
    addexp     go to state 18
    mulexp     go to state 19
    unaryexp   go to state 20
    atomexp    go to state 21
    idexp      go to state 22
    lvalue     go to state 23


